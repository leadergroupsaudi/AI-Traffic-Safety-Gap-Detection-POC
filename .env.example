# ─────────────────────────────────────────────────────────────
# AI Traffic Safety — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────
# Leave blank to disable AI recommendations gracefully
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Data files ────────────────────────────────────────────────
FINDINGS_CSV=data/exports/findings.csv
TRACKING_XLSX=data/raw/unique_objects_tracking_old.xlsx
RULES_YAML=rules/saudi_traffic_rules.yaml

# ── Directories ───────────────────────────────────────────────
SNAPSHOTS_DIR=snapshots
MEDIA_DIR=media
UPLOAD_DIR=media/uploads
TRACKING_OUTPUT_DIR=data/raw

# ── ML pipeline inputs (offline scripts only) ─────────────────
# Full path to the YOLO .pt model file
MODEL_PATH=/path/to/your/model.pt
# Path to the input survey video
VIDEO_PATH=Sample_full_video.mp4
